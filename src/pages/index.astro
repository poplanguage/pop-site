---
import Layout from "../layouts/Layout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import BubbleField from "../components/BubbleField.astro";
import CodeWindow from "../components/CodeWindow.astro";
import FeatureCard from "../components/FeatureCard.astro";
import PopMark from "../components/PopMark.astro";

const bookUrl = "https://poplanguage.github.io/book/";

const playerCode = [
  '<span class="tok-keyword">namespace</span> Hello',
  '',
  '<span class="tok-keyword">function</span> <span class="tok-fn">main</span>()',
  '    <span class="tok-keyword">local</span> release = <span class="tok-string">"0.1.0-rc.3"</span>',
  '    <span class="tok-fn">print</span>(<span class="tok-string">`🫧 Hello from Pop {release}!`</span>)',
  '    <span class="tok-fn">print</span>(<span class="tok-string">"Strong types. Native code. Small syntax."</span>)',
  '<span class="tok-keyword">end</span>',
];

const resultCode = [
  '<span class="tok-keyword">public union</span> <span class="tok-type">SearchResult</span>',
  '    Found(value: <span class="tok-type">String</span>)',
  '    Missing',
  '<span class="tok-keyword">end</span>',
  '',
  '<span class="tok-keyword">function</span> <span class="tok-fn">describe</span>(result: <span class="tok-type">SearchResult</span>)',
  '    <span class="tok-keyword">match</span> result',
  '    <span class="tok-keyword">when</span> SearchResult.Found(name) <span class="tok-keyword">then</span>',
  '        <span class="tok-fn">print</span>(<span class="tok-string">`Found {name}`</span>)',
  '    <span class="tok-keyword">when</span> SearchResult.Missing <span class="tok-keyword">then</span>',
  '        <span class="tok-fn">print</span>(<span class="tok-string">"Nothing was found"</span>)',
  '    <span class="tok-keyword">end</span>',
  '<span class="tok-keyword">end</span>',
];

const inferenceExample = [
  '<span class="mini-keyword">namespace</span> Scores',
  '',
  '<span class="mini-keyword">function</span> main()',
  '    <span class="mini-keyword">local</span> score = <span class="mini-value">10</span>',
  '    print(score)',
  '<span class="mini-keyword">end</span>',
];

const recordExample = [
  '<span class="mini-keyword">public record</span> <span class="mini-type">Player</span>',
  '    name: <span class="mini-type">String</span>',
  '    score: <span class="mini-type">Int</span> = <span class="mini-value">0</span>',
  '<span class="mini-keyword">end</span>',
];

const resultExample = [
  '<span class="mini-keyword">public union</span> <span class="mini-type">SearchResult</span>',
  '    Found(value: <span class="mini-type">String</span>)',
  '    Missing',
  '<span class="mini-keyword">end</span>',
];

const performanceExample = [
  '<span class="mini-command">pop check hello.pop</span>',
  '',
  '<span class="mini-command">pop build hello.pop --output hello</span>',
  '<span class="mini-command">./hello</span>',
];
---

<Layout>
  <div class="hero-wrap" id="top">
    <BubbleField />
    <SiteHeader />

    <main id="main-content">
      <section class="hero shell" aria-labelledby="hero-title">
        <div class="hero-copy">
          <p class="eyebrow">00 / A language in active development</p>
          <h1 id="hero-title">Simple by nature.<br /><em>Powerful by design.</em></h1>
          <p class="hero-lede">
            Pop keeps code light, readable, and familiar—then gives every value a real type and every program a predictable native foundation.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href={bookUrl}>
              Read the Pop Book
              <span aria-hidden="true">↗</span>
            </a>
            <a class="button button-secondary" href="https://github.com/poplanguage/pop">
              Explore the source
              <span aria-hidden="true">→</span>
            </a>
          </div>
          <p class="hero-note"><span>pop</span> Native · strongly typed · Luau-inspired</p>
        </div>

        <div class="hero-code">
          <CodeWindow filename="hello.pop" lines={playerCode} />
        </div>
      </section>

      <div class="ticker" aria-label="Pop language characteristics">
        <div class="ticker-track">
          <span>Static without the noise</span><i></i><span>Portable by architecture</span><i></i><span>Data first</span><i></i><span>No dynamic fallback</span><i></i><span>Typed failures</span><i></i><span>Static without the noise</span><i></i><span>Portable by architecture</span><i></i><span>Data first</span><i></i><span>No dynamic fallback</span><i></i><span>Typed failures</span>
        </div>
      </div>
    </main>
  </div>

  <section class="principles" id="language" aria-labelledby="principles-title">
    <div class="shell principles-grid">
      <header class="section-intro">
        <p class="eyebrow">01 / Why Pop?</p>
        <h2 id="principles-title">Nothing hiding<br />behind the syntax.</h2>
        <p>
          Lightweight languages often move complexity into the runtime. Pop makes a different trade: a small surface with explicit semantics that developers, editors, and compilers can all agree on.
        </p>
        <a class="text-link" href={bookUrl}>Tour the language <span aria-hidden="true">↗</span></a>
      </header>

      <div class="feature-grid">
        <FeatureCard number="01" title="Static, not noisy" tone="coral" filename="scores.pop" lines={inferenceExample}>
          Local inference keeps declarations short. There is no <code>any</code> or dynamic escape hatch underneath them.
        </FeatureCard>
        <FeatureCard number="02" title="Real language shapes" tone="plain" filename="player.pop" lines={recordExample}>
          Records are records. Classes are classes. Arrays, tables, modules, and namespaces keep distinct, dependable meanings.
        </FeatureCard>
        <FeatureCard number="03" title="States must be handled" tone="plain" filename="search-result.pop" lines={resultExample}>
          Tagged unions make every state visible. Exhaustive matching keeps new cases from slipping past callers.
        </FeatureCard>
        <FeatureCard number="04" title="Performance, by design" tone="mint" filename="terminal" lines={performanceExample}>
          Simplicity with the performance of C, D, and Rust. Pop is designed for efficient native binaries across portable backends.
        </FeatureCard>
      </div>
    </div>
  </section>

  <section class="performance-statement" aria-labelledby="performance-title">
    <div class="performance-lines" aria-hidden="true">
      <i></i><i></i><i></i><i></i><i></i><i></i>
    </div>
    <div class="shell performance-grid">
      <div class="performance-index">
        <span>04</span>
        <p>Native<br />foundation</p>
      </div>
      <div class="performance-copy">
        <p class="eyebrow">Performance without the punctuation tax</p>
        <h2 id="performance-title">
          Simplicity with the performance of <em>C</em>, <em>D</em>, and <em>Rust</em>.
        </h2>
        <div class="performance-foot">
          <p>Small, readable source on the front. Typed HIR, verified MIR, and portable native backends underneath.</p>
          <code>source.pop → HIR → MIR → native</code>
        </div>
      </div>
    </div>
  </section>

  <section class="syntax-section" aria-labelledby="syntax-title">
    <div class="syntax-pattern" aria-hidden="true"></div>
    <div class="shell syntax-shell">
      <header class="syntax-heading">
        <div>
          <p class="eyebrow">02 / The feel of Pop</p>
          <h2 id="syntax-title">Readable at a glance.<br /><em>Strict all the way down.</em></h2>
        </div>
        <p>
          Familiar <code>end</code>-based blocks, local inference, first-class functions, and collection literals—built for general-purpose software from day one.
        </p>
      </header>

      <div class="syntax-stage">
        <div class="syntax-notes" aria-label="Code explanation">
          <div class="note note-one"><span>01</span><p>A tagged union gives each state a name and shape.</p></div>
          <div class="note note-two"><span>02</span><p><code>match</code> is exhaustive. Add a case and callers must handle it.</p></div>
          <div class="note note-three"><span>03</span><p>Types stay precise without repeating what the compiler already knows.</p></div>
        </div>
        <CodeWindow filename="pattern-matching.pop" compact={true} lines={resultCode} />
      </div>
    </div>
  </section>

  <section class="bubble-architecture" aria-labelledby="bubble-title">
    <div class="shell architecture-grid">
      <div class="architecture-copy">
        <p class="eyebrow">03 / A unit called Bubble</p>
        <h2 id="bubble-title">Structure that scales without becoming ceremony.</h2>
        <p>
          Every <code>.pop</code> file is a Module. Modules compile together inside a Bubble—the boundary for internal visibility and independent dependencies.
        </p>
        <div class="manifest"><span>bubble.toml</span><span>→</span><span>clear ownership</span></div>
      </div>

      <div class="orbit-system" aria-label="Pop code ownership hierarchy: Item, Module, Bubble, Package, Workspace">
        <div class="orbit orbit-5"><span>Workspace</span></div>
        <div class="orbit orbit-4"><span>Package</span></div>
        <div class="orbit orbit-3"><span>Bubble</span></div>
        <div class="orbit orbit-2"><span>Module</span></div>
        <div class="orbit orbit-1"><span>Item</span></div>
      </div>
    </div>
  </section>

  <section class="toolchain" id="toolchain" aria-labelledby="toolchain-title">
    <div class="shell">
      <header class="toolchain-heading">
        <p class="eyebrow">04 / One coherent toolchain</p>
        <h2 id="toolchain-title">From first check<br />to final build.</h2>
        <p>One command, one vocabulary, stable structured output for editors and build systems.</p>
      </header>
      <div class="commands" role="list" aria-label="Pop toolchain commands">
        <div role="listitem"><span>01</span><code>pop check</code><b>prove it</b></div>
        <div role="listitem"><span>02</span><code>pop build</code><b>compile it</b></div>
        <div role="listitem"><span>03</span><code>pop run</code><b>run it</b></div>
        <div role="listitem"><span>04</span><code>pop test</code><b>trust it</b></div>
        <div role="listitem"><span>05</span><code>pop format</code><b>shape it</b></div>
      </div>
    </div>
  </section>

  <section class="status-section" aria-labelledby="status-title">
    <div class="status-bubble status-one" aria-hidden="true"></div>
    <div class="status-bubble status-two" aria-hidden="true"></div>
    <div class="shell status-grid">
      <div class="status-copy">
        <p class="eyebrow">05 / Built in public</p>
        <h2 id="status-title">A language you can watch becoming.</h2>
        <p>
          Pop is under active development and is not production-ready yet. The source of truth is public: architecture decisions, compiler foundations, runtime work, and conformance tests.
        </p>
        <div class="status-actions">
          <a class="button status-primary" href="https://github.com/poplanguage/pop">Follow the work <span>↗</span></a>
          <a class="status-book" href={bookUrl}>Read the book <span>↗</span></a>
        </div>
      </div>

      <ol class="status-ledger" aria-label="Pop development status">
        <li><span>01</span><div><strong>Language architecture</strong><small>Accepted decisions and invariants</small></div><b>active</b></li>
        <li><span>02</span><div><strong>Compiler foundation</strong><small>Parser, HIR, MIR, diagnostics</small></div><b>active</b></li>
        <li><span>03</span><div><strong>Native runtime</strong><small>Values, GC, ABI, backends</small></div><b>active</b></li>
        <li class="status-muted"><span>04</span><div><strong>Production readiness</strong><small>Not stable yet</small></div><b>later</b></li>
      </ol>
    </div>
  </section>

  <footer>
    <div class="shell footer-grid">
      <div class="footer-brand">
        <PopMark size={44} />
        <div><strong>Pop</strong><span>Simple by nature. Powerful by design.</span></div>
      </div>
      <nav aria-label="Footer navigation">
        <a href="#language">Language</a>
        <a href={bookUrl}>Book ↗</a>
        <a href="https://github.com/poplanguage/pop">GitHub</a>
        <a href="https://discord.gg/wkCSZrFyd5">Discord</a>
      </nav>
      <p>Designed for clarity.<br />Built in the open.</p>
    </div>
  </footer>
</Layout>

<style>
  .hero-wrap {
    position: relative;
    overflow: hidden;
    color: var(--paper);
    background-color: var(--ink);
    background-image: radial-gradient(rgb(184 244 255 / 0.09) 0.7px, transparent 0.7px);
    background-size: 18px 18px;
  }

  .hero {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.04fr) minmax(25rem, 0.96fr);
    align-items: center;
    gap: clamp(3rem, 6vw, 7rem);
    min-height: min(720px, calc(100svh - 97px));
    padding-block: clamp(3.5rem, 5vw, 5rem);
  }

  .hero-copy { position: relative; z-index: 2; }

  .hero h1 {
    margin: 0;
    max-width: 10ch;
    font-family: var(--font-display);
    font-size: clamp(3.8rem, 6.3vw, 6.3rem);
    font-weight: 500;
    line-height: 0.84;
    letter-spacing: -0.065em;
  }

  .hero h1 em {
    color: var(--pop-cyan);
    font-weight: 500;
  }

  .hero-lede {
    max-width: 38rem;
    margin: 1.6rem 0 0;
    color: #aac8d0;
    font-size: clamp(0.94rem, 1.2vw, 1.08rem);
    line-height: 1.65;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.7rem;
  }

  .hero-note {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1.8rem 0 0;
    color: #66818a;
    font-family: var(--font-mono);
    font-size: 0.67rem;
    letter-spacing: 0.04em;
  }

  .hero-note span {
    padding: 0.3rem 0.45rem;
    border: 1px solid var(--line-dark);
    border-radius: 0.35rem;
    color: var(--pop-ice);
  }

  .hero-code {
    position: relative;
    z-index: 2;
    max-width: 100%;
    min-width: 0;
    transform: rotate(1.5deg);
  }

  .hero-code::before {
    content: "";
    position: absolute;
    inset: 1.5rem -0.8rem -0.8rem 0.8rem;
    z-index: -1;
    border: 1px solid rgb(25 184 230 / 0.45);
    border-radius: 0.7rem;
  }

  .ticker {
    position: relative;
    z-index: 2;
    overflow: hidden;
    border-top: 1px solid var(--line-dark);
    border-bottom: 1px solid var(--line-dark);
    background: #091d24;
  }

  .ticker-track {
    display: flex;
    align-items: center;
    width: max-content;
    padding-block: 1.1rem;
    animation: ticker 35s linear infinite;
  }

  .ticker span {
    padding-inline: 2rem;
    color: #87a5ae;
    font-family: var(--font-mono);
    font-size: 0.66rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .ticker i {
    width: 0.48rem;
    height: 0.48rem;
    border-radius: 50%;
    background: var(--pop-blue);
  }

  @keyframes ticker { to { transform: translateX(-50%); } }

  .principles {
    position: relative;
    padding-block: clamp(4rem, 6vw, 6rem);
    background: var(--paper);
  }

  .principles::before {
    content: "WHY";
    position: absolute;
    top: 2rem;
    right: 1rem;
    color: rgb(7 24 30 / 0.025);
    font-family: var(--font-sans);
    font-size: clamp(9rem, 22vw, 22rem);
    font-weight: 900;
    line-height: 0.75;
    letter-spacing: -0.09em;
  }

  .principles-grid {
    display: grid;
    gap: clamp(2.5rem, 4vw, 4rem);
  }

  .section-intro {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(18rem, 0.72fr);
    align-items: end;
    column-gap: clamp(3rem, 9vw, 9rem);
  }

  .section-intro .eyebrow { grid-column: 1 / -1; }
  .section-intro h2 { grid-row: 2 / span 2; max-width: 12ch; }

  .principles .eyebrow,
  .syntax-section .eyebrow,
  .toolchain .eyebrow { color: #46636c; }

  .section-intro h2,
  .syntax-heading h2,
  .architecture-copy h2,
  .toolchain h2,
  .status-copy h2 {
    margin: 0;
    font-family: var(--font-display);
    font-size: clamp(2.8rem, 5vw, 4.8rem);
    font-weight: 500;
    line-height: 0.9;
    letter-spacing: -0.055em;
  }

  .section-intro > p:not(.eyebrow) {
    max-width: 31rem;
    margin: 0;
    color: var(--ink-soft);
    font-size: 1rem;
    line-height: 1.7;
  }

  .text-link {
    display: inline-flex;
    gap: 1.5rem;
    margin-top: 1.4rem;
    padding-bottom: 0.35rem;
    border-bottom: 1px solid var(--ink);
    font-size: 0.8rem;
    font-weight: 750;
  }

  .feature-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    column-gap: clamp(2rem, 5vw, 5rem);
  }

  .performance-statement {
    position: relative;
    overflow: hidden;
    color: var(--paper);
    background: var(--pop-deep);
  }

  .performance-grid {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    min-height: 31rem;
    padding-block: clamp(4rem, 6vw, 6rem);
  }

  .performance-index {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding-bottom: 1rem;
    border-bottom: 1px solid rgb(184 244 255 / 0.24);
    font-family: var(--font-mono);
  }

  .performance-index > span {
    color: var(--pop-ice);
    font-size: 0.72rem;
  }

  .performance-index p {
    margin: 0;
    color: rgb(239 249 250 / 0.55);
    font-size: 0.63rem;
    line-height: 1.5;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    text-align: right;
  }

  .performance-copy {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .performance-copy .eyebrow::before {
    background: var(--pop-cyan);
  }

  .performance-copy h2 {
    max-width: 15ch;
    margin: 1rem 0 2.5rem;
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 6.5vw, 6.5rem);
    font-weight: 500;
    line-height: 0.88;
    letter-spacing: -0.06em;
  }

  .performance-copy h2 em {
    color: var(--pop-cyan);
    font-weight: 500;
  }

  .performance-foot {
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: end;
    gap: 3rem;
    padding-top: 1.5rem;
    border-top: 1px solid rgb(184 244 255 / 0.24);
  }

  .performance-foot p {
    max-width: 37rem;
    margin: 0;
    color: rgb(239 249 250 / 0.7);
    font-size: 0.88rem;
    line-height: 1.65;
  }

  .performance-foot code {
    color: var(--pop-ice);
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .performance-lines {
    position: absolute;
    inset: 0;
    opacity: 0.12;
    transform: rotate(-11deg) scale(1.2);
  }

  .performance-lines i {
    position: absolute;
    right: -10%;
    display: block;
    height: 1px;
    background: var(--pop-cyan);
  }

  .performance-lines i:first-child { top: 14%; width: 65%; }
  .performance-lines i:nth-child(2) { top: 28%; width: 45%; }
  .performance-lines i:nth-child(3) { top: 42%; width: 72%; }
  .performance-lines i:nth-child(4) { top: 57%; width: 36%; }
  .performance-lines i:nth-child(5) { top: 72%; width: 58%; }
  .performance-lines i:last-child { top: 86%; width: 78%; }

  .syntax-section {
    position: relative;
    overflow: hidden;
    padding-block: clamp(4rem, 6vw, 6rem);
    background: var(--paper-deep);
  }

  .syntax-pattern {
    position: absolute;
    inset: 0;
    opacity: 0.55;
    background-image: repeating-linear-gradient(135deg, transparent 0 34px, rgb(7 24 30 / 0.035) 34px 35px);
  }

  .syntax-shell { position: relative; }

  .syntax-heading {
    display: grid;
    grid-template-columns: 1.3fr 0.7fr;
    align-items: end;
    gap: 4rem;
    margin-bottom: clamp(3rem, 5vw, 5rem);
  }

  .syntax-heading h2 em {
    color: var(--pop-deep);
    font-weight: 500;
  }

  .syntax-heading > p {
    max-width: 34rem;
    margin: 0 0 0.65rem;
    color: var(--ink-soft);
    line-height: 1.7;
  }

  .syntax-stage {
    display: grid;
    grid-template-columns: 0.62fr 1.38fr;
    gap: clamp(2rem, 6vw, 6rem);
    align-items: center;
  }

  .syntax-stage > * { min-width: 0; }

  .syntax-notes { display: grid; gap: 1rem; }

  .note {
    display: grid;
    grid-template-columns: 2.7rem 1fr;
    gap: 1rem;
    padding: 1.2rem;
    border-top: 1px solid var(--line);
  }

  .note span {
    font-family: var(--font-mono);
    font-size: 0.68rem;
  }

  .note p {
    max-width: 29rem;
    margin: 0;
    color: var(--ink-soft);
    font-size: 0.88rem;
    line-height: 1.6;
  }

  .note-one span { color: var(--pop-deep); }
  .note-two span { color: #118cae; }
  .note-three span { color: #0a6b88; }

  .bubble-architecture {
    overflow: hidden;
    color: var(--paper);
    background: var(--ink);
  }

  .architecture-grid {
    display: grid;
    grid-template-columns: 0.82fr 1.18fr;
    align-items: center;
    gap: 3rem;
    min-height: 35rem;
    padding-block: 4rem;
  }

  .architecture-copy h2 {
    max-width: 9ch;
    font-size: clamp(2.8rem, 5vw, 4.6rem);
  }

  .architecture-copy > p:not(.eyebrow) {
    max-width: 32rem;
    margin: 2rem 0 0;
    color: var(--muted-on-dark);
    line-height: 1.7;
  }

  .manifest {
    display: inline-flex;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding: 0.8rem 1rem;
    border: 1px solid var(--line-dark);
    border-radius: 0.6rem;
    color: var(--pop-ice);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }

  .orbit-system {
    position: relative;
    width: min(100%, 34rem);
    aspect-ratio: 1;
    justify-self: end;
  }

  .orbit {
    position: absolute;
    top: 50%;
    left: 50%;
    display: grid;
    place-items: center;
    border: 1px solid rgb(184 244 255 / 0.2);
    border-radius: 50%;
    transform: translate(-50%, -50%);
  }

  .orbit span {
    position: absolute;
    top: 50%;
    right: -0.7rem;
    padding: 0.4rem 0.6rem;
    border-radius: 99px;
    color: var(--ink);
    background: var(--paper);
    font-family: var(--font-mono);
    font-size: 0.62rem;
  }

  .orbit-5 { width: 100%; height: 100%; border-color: rgb(25 184 230 / 0.52); }
