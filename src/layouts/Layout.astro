---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Pop — Simple by nature. Powerful by design.",
  description = "Pop is a native, strongly and statically typed programming language with the lightweight feel of Luau.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#07181e" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <link rel="icon" type="image/svg+xml" href="/pop.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to content</a>
    <slot />
  </body>
</html>
