---
const popMarkUrl = `${import.meta.env.BASE_URL}/pop.svg`;
---

<div class="bubble-field" aria-hidden="true">
  <span class="bubble bubble-a"></span>
  <span class="bubble bubble-b"></span>
  <span class="bubble bubble-c"></span>
  <span class="bubble bubble-d"></span>
  <span class="bubble bubble-e"></span>
  <span class="orb orb-a"></span>
  <span class="orb orb-b"></span>
  <img class="bubble-echo" src={popMarkUrl} alt="" />
</div>

<style>
  .bubble-field {
    position: absolute;
    inset: 0;
    overflow: hidden;
    pointer-events: none;
  }

  .bubble,
  .orb {
    position: absolute;
    display: block;
    border-radius: 50%;
  }

  .bubble {
    border: 1px solid rgb(184 244 255 / 0.18);
    box-shadow:
      inset -12px -14px 35px rgb(255 255 255 / 0.025),
      inset 9px 9px 20px rgb(255 255 255 / 0.06);
    animation: float 11s ease-in-out infinite alternate;
  }

  .bubble::after {
    content: "";
    position: absolute;
    top: 18%;
    left: 22%;
    width: 18%;
    height: 10%;
    border-radius: 50%;
    background: rgb(255 255 255 / 0.17);
    transform: rotate(-28deg);
  }

  .bubble-a {
    width: 22rem;
    height: 22rem;
    right: -9rem;
    top: 8rem;
    border-color: rgb(25 184 230 / 0.4);
  }

  .bubble-b {
    width: 7rem;
    height: 7rem;
    left: 42%;
    top: 8%;
    animation-delay: -4s;
  }

  .bubble-c {
    width: 14rem;
    height: 14rem;
    left: -7rem;
    bottom: 4rem;
    border-color: rgb(184 244 255 / 0.25);
    animation-delay: -7s;
  }

  .bubble-d {
    width: 4.5rem;
    height: 4.5rem;
    right: 46%;
    bottom: 8%;
    animation-delay: -2s;
  }

  .bubble-e {
    width: 2.5rem;
    height: 2.5rem;
    right: 11%;
    bottom: 16%;
    border-color: rgb(93 235 255 / 0.35);
    animation-delay: -8s;
  }

  .orb {
    filter: blur(80px);
    opacity: 0.14;
  }

  .orb-a {
    width: 26rem;
    height: 26rem;
    top: -13rem;
    right: 16%;
    background: var(--pop-blue);
  }

  .orb-b {
    width: 20rem;
    height: 20rem;
    bottom: -10rem;
    left: 22%;
    background: var(--pop-ice);
  }

  .bubble-echo {
    position: absolute;
    width: min(46vw, 44rem);
    height: auto;
    right: -15rem;
    top: 7rem;
    opacity: 0.055;
    filter: saturate(0) brightness(3);
    transform: rotate(-12deg);
  }

  @keyframes float {
    from { transform: translate3d(0, -8px, 0) rotate(-2deg); }
    to { transform: translate3d(8px, 16px, 0) rotate(2deg); }
  }

  @media (prefers-reduced-motion: reduce) {
    .bubble { animation: none; }
  }
</style>
