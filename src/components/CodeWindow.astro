---
interface Props {
  filename?: string;
  compact?: boolean;
  lines: string[];
}

const { filename = "main.pop", compact = false, lines } = Astro.props;
---

<div class:list={["code-window", { compact }]}>
  <div class="code-bar">
    <span class="code-dot" aria-hidden="true"></span>
    <span>{filename}</span>
    <span class="filetype">POP</span>
  </div>
  <pre><code>{lines.map((line) => <span class="code-line" set:html={line}></span>)}</code></pre>
</div>

<style>
  .code-window {
    position: relative;
    width: 100%;
    max-width: 100%;
    min-width: 0;
    overflow: hidden;
    border: 1px solid rgb(184 244 255 / 0.17);
    border-radius: 0.35rem;
    background: #091d24;
    box-shadow: 0 22px 60px rgb(0 0 0 / 0.28);
  }

  .code-bar {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    min-height: 46px;
    padding: 0 1rem;
    border-bottom: 1px solid rgb(184 244 255 / 0.1);
    color: #8eabb4;
    font-family: var(--font-mono);
    font-size: 0.67rem;
  }

  .code-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: var(--pop-blue);
    box-shadow: 0 0 0 4px rgb(25 184 230 / 0.12);
  }

  .filetype {
    justify-self: end;
    color: #53707a;
    font-size: 0.58rem;
    letter-spacing: 0.12em;
  }

  pre {
    counter-reset: code-line;
    margin: 0;
    padding: clamp(1.25rem, 3vw, 2rem) clamp(0.9rem, 2vw, 1.3rem);
    overflow-x: auto;
    max-width: 100%;
    color: #d8f3f7;
    font-family: var(--font-mono);
    font-size: clamp(0.73rem, 1.1vw, 0.92rem);
    line-height: 1.75;
    tab-size: 4;
  }

  pre > code {
    display: block;
    min-width: max-content;
    font-family: inherit;
  }

  .code-line {
    position: relative;
    display: block;
    min-height: 1.75em;
    padding-left: 2.7rem;
    white-space: pre;
    counter-increment: code-line;
  }

  .code-line::before {
    content: counter(code-line, decimal-leading-zero);
    position: absolute;
    top: 0;
    left: 0;
    width: 1.85rem;
    color: #34515b;
    font-size: 0.58rem;
    text-align: right;
    user-select: none;
  }

  .compact pre {
    min-height: 20rem;
    font-size: clamp(0.72rem, 1vw, 0.84rem);
  }

  :global(.tok-keyword) { color: #5debff; }
  :global(.tok-type) { color: #91cfff; }
  :global(.tok-string) { color: #b8f4ff; }
  :global(.tok-fn) { color: #72ddc1; }
  :global(.tok-comment) { color: #55717a; font-style: italic; }
  :global(.tok-value) { color: #d8fcff; }

  @media (max-width: 600px) {
    pre {
      padding: 1rem 0.6rem;
      font-size: 0.64rem;
    }

    .compact pre { font-size: 0.64rem; }

    .code-line { padding-left: 2.1rem; }

    .code-line::before {
      width: 1.35rem;
      font-size: 0.52rem;
    }
  }
</style>
