  <div class="repo-details">
    <strong>GitHub</strong>
    <ul aria-label="Repository facts">
      <li class="version" title="Latest tag"><span data-repo-version>v0.1.0-rc.3</span></li>
      <li class="stars" title="Stars"><span aria-hidden="true">★</span> <span data-repo-stars>16</span></li>
      <li class="forks" title="Forks"><span aria-hidden="true">⑂</span> <span data-repo-forks>3</span></li>
    </ul>
  </div>
</a>

<script>
  const source = document.querySelector<HTMLElement>("[data-repo-source]");

  const formatCount = (value: number) => {
    if (value < 1000) return String(value);
    return `${(value / 1000).toFixed(value < 10000 ? 1 : 0)}k`;
  };

  if (source) {
    Promise.all([
      fetch("https://api.github.com/repos/poplanguage/pop", { headers: { Accept: "application/vnd.github+json" } }),
      fetch("https://api.github.com/repos/poplanguage/pop/tags?per_page=1", { headers: { Accept: "application/vnd.github+json" } }),
    ])
      .then(async ([repoResponse, tagsResponse]) => {
        if (!repoResponse.ok || !tagsResponse.ok) return;

        const repo = await repoResponse.json();
        const tags = await tagsResponse.json();
        const version = source.querySelector<HTMLElement>("[data-repo-version]");
        const stars = source.querySelector<HTMLElement>("[data-repo-stars]");
        const forks = source.querySelector<HTMLElement>("[data-repo-forks]");

        if (version && Array.isArray(tags) && tags[0]?.name) version.textContent = tags[0].name;
        if (stars && Number.isFinite(repo.stargazers_count)) stars.textContent = formatCount(repo.stargazers_count);
        if (forks && Number.isFinite(repo.forks_count)) forks.textContent = formatCount(repo.forks_count);
      })
      .catch(() => {});
  }
</script>

<style>
  .repo-source {
    display: grid;
    grid-template-columns: 2rem 1fr;
    align-items: center;
    justify-self: end;
    gap: 0.75rem;
    min-width: 12.5rem;
    padding-left: 1.25rem;
    border-left: 1px solid var(--line-dark);
    color: var(--muted-on-dark);
    transition: color 160ms ease;
  }

  .repo-source:hover { color: var(--paper); }

  .repo-icon {
    display: grid;
    place-items: center;
    width: 2rem;
    height: 2rem;
  }

  .repo-icon svg {
    width: 1.55rem;
    height: 1.55rem;
    fill: currentColor;
  }

  .repo-details strong {
    display: block;
    color: var(--paper);
    font-size: 0.84rem;
    font-weight: 700;
    line-height: 1;
  }

  ul {
    display: flex;
    gap: 0.85rem;
    margin: 0.38rem 0 0;
    padding: 0;
    color: #78949d;
    font-family: var(--font-mono);
    font-size: 0.6rem;
    line-height: 1;
    list-style: none;
  }

  li { white-space: nowrap; }
  .version { color: #73dff4; }

  @media (max-width: 900px) {
    .repo-source {
      grid-template-columns: 1.65rem;
      min-width: 0;
      gap: 0;
      padding-left: 0;
      border-left: 0;
    }

    .repo-icon { width: 1.65rem; height: 1.65rem; }
    .repo-icon svg { width: 1.3rem; height: 1.3rem; }
    .repo-details { display: none; }
  }
</style>
